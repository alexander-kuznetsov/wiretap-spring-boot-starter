<?xml version="1.0" encoding="UTF-8"?>
<included>
    <include optional="false" resource="logback-properties.xml"/>

    <if condition='property("isLoggingFile").equals("true")'>
        <then>
            <appender name="FILE-ROLLING" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <file>${loggingPath}/${APP_NAME}_json.log</file>
                <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                    <fileNamePattern>${loggingPath}/archive/${APP_NAME}_json_%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                    <maxHistory>3</maxHistory>
                    <maxFileSize>100MB</maxFileSize>
                    <totalSizeCap>10GB</totalSizeCap>
                </rollingPolicy>
                <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                    <if condition='property("isPrettyLog").equals("true")'>
                        <then>
                            <jsonGeneratorDecorator class="net.logstash.logback.decorate.PrettyPrintingJsonGeneratorDecorator"/>
                        </then>
                    </if>
                    <providers>
                        <provider class="io.wiretap.applog.provider.LazyStandardLogFieldsProvider"/>
                        <stackTrace>
                            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                                <maxDepthPerThrowable>${stackTraceMaxDepth}</maxDepthPerThrowable>
                                <maxLength>${stackTraceMaxLength}</maxLength>
                                <rootCauseFirst>true</rootCauseFirst>
                            </throwableConverter>
                        </stackTrace>
                        <provider class="io.wiretap.applog.provider.WiretapDelegatingLogFieldProvider"/>
                    </providers>
                </encoder>
                <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
                    <evaluator>
                        <expression>logger.equals("brave.Tracer")</expression>
                    </evaluator>
                    <OnMismatch>NEUTRAL</OnMismatch>
                    <OnMatch>DENY</OnMatch>
                </filter>
            </appender>

            <if condition='property("isAsyncLogging").equals("true")'>
                <then>
                    <appender name="ASYNC-FILE" class="ch.qos.logback.classic.AsyncAppender">
                        <queueSize>${asyncQueueSize}</queueSize>
                        <neverBlock>${asyncNeverBlock}</neverBlock>
                        <discardingThreshold>${asyncDiscardingThreshold}</discardingThreshold>
                        <appender-ref ref="FILE-ROLLING"/>
                    </appender>
                    <root level="INFO">
                        <appender-ref ref="ASYNC-FILE"/>
                    </root>
                </then>
                <else>
                    <root level="INFO">
                        <appender-ref ref="FILE-ROLLING"/>
                    </root>
                </else>
            </if>
        </then>
    </if>
</included>