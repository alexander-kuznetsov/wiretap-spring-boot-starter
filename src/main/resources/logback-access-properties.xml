<?xml version="1.0" encoding="UTF-8"?>
<included>
    <property resource="application.properties"/>
    <property resource="application.yml"/>
    <springProperty scope="context" name="isPrettyLog" source="wiretap.pretty-print" defaultValue="false"/>
    <springProperty scope="context" name="defaultLog" source="wiretap.default-log" defaultValue="false"/>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name"/>
    <springProperty scope="context" name="ACTIVE_PROFILE" source="spring.profiles.active"/>
    <!-- always a good activate OnConsoleStatusListener -->
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>
    <springProperty scope="context" name="isLoggingFile" source="wiretap.file-logging-enabled" defaultValue="false"/>
    <springProperty scope="context" name="loggingPath" source="wiretap.file-logging-path" defaultValue="/var/log/wiretap"/>

    <!-- Access log top-level field names (override via wiretap.access-log.fields.*) -->
    <springProperty scope="context" name="f_timestamp"   source="wiretap.access-log.fields.timestamp"    defaultValue="@timestamp"/>
    <springProperty scope="context" name="f_env"         source="wiretap.access-log.fields.env"           defaultValue="env"/>
    <springProperty scope="context" name="f_system"      source="wiretap.access-log.fields.system"        defaultValue="system"/>
    <springProperty scope="context" name="f_inst"        source="wiretap.access-log.fields.instance"      defaultValue="inst"/>
    <springProperty scope="context" name="f_lb_trace_id" source="wiretap.access-log.fields.lb-trace-id"   defaultValue="lb_trace_id"/>
    <springProperty scope="context" name="f_level"       source="wiretap.access-log.fields.level"         defaultValue="level"/>
</included>
